{
  "builds": [
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "25mb"
      }
    }
  ],
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/backend/app/main.py" },
    { "source": "/auth", "destination": "/backend/app/main.py" },
    { "source": "/schools/:path*", "destination": "/backend/app/main.py" },
    { "source": "/schools", "destination": "/backend/app/main.py" },
    { "source": "/zonasi/:path*", "destination": "/backend/app/main.py" },
    { "source": "/zonasi", "destination": "/backend/app/main.py" },
    { "source": "/map/:path*", "destination": "/backend/app/main.py" },
    { "source": "/map", "destination": "/backend/app/main.py" },
    { "source": "/operator/:path*", "destination": "/backend/app/main.py" },
    { "source": "/operator", "destination": "/backend/app/main.py" }
  ]
}
